# Copy to .env for local development — `npm run dev` starts both Vite and
# a small local API server (scripts/dev-api-server.mjs, proxied at /api by
# vite.config.js) that runs the SAME api/harshbot.js handler used in
# production, so these variables take effect locally too.
# NEVER commit a real .env file (already covered by .gitignore).
#
# NOTE: plain Node does not auto-load .env files. Either export these in
# your shell before `npm run dev`, or use a tool like `node --env-file=.env`.

# Server-only — read exclusively by api/harshbot.js. Never prefix this
# with VITE_, which would bundle it into client-side JavaScript. If unset,
# HarshBot still works using only its deterministic local portfolio
# knowledge (no LLM tier) — it never fails the build and never disables
# the composer.
OPENAI_API_KEY=

# Optional — overrides the default model (gpt-5.4-mini) used by
# api/harshbot.js. Server-only; not read by the frontend.
OPENAI_MODEL=gpt-5.4-mini

# Optional — port for the local dev-only API server started by
# `npm run dev` (scripts/dev-api-server.mjs). Must match if you also
# change vite.config.js's proxy target. Defaults to 8787.
HARSHBOT_API_PORT=8787

# Optional, NOT secret — only needed if the HarshBot API is ever deployed
# separately from the frontend (e.g. frontend on GitHub Pages, API on its
# own Vercel/Cloudflare/Netlify deployment). Safe to expose to the browser
# since it's just a URL, never a credential. Defaults to the same-origin
# "/api/harshbot" when unset.
VITE_HARSHBOT_API_URL=

# Used by scripts/update-github-data.mjs (see that file's own header
# comment for full usage) — unrelated to HarshBot, listed here only to
# keep every server-side secret documented in one place.
GITHUB_ACTIVITY_TOKEN=
